# Database
# Local Postgres example:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SYNCHRONIZE=true

# Railway + Supabase note:
# If your Supabase direct host (db.<project>.supabase.co) resolves to IPv6 and Railway cannot reach it,
# use the Supabase pooler host instead (for example aws-0-<region>.pooler.supabase.com).

# JWT
JWT_SECRET=valkiric-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Brevo HTTPS API (recommended for production on Railway)
BREVO_API_KEY=your-brevo-api-key
SMTP_FROM=Valkiric <verified-sender@example.com>

# SMTP fallback
# Use this only if you explicitly want SMTP instead of the Brevo HTTPS API.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=20000
